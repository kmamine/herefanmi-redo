# HeReFaNMi configuration. Copy to .env and adjust. All vars are prefixed HRF_.
# Every service reads these via shared/hrf_shared/config.py (pydantic-settings).

# ---- LLM provider (OpenAI-compatible API) ----
# Default targets a local vLLM server. Swapping providers is purely an env change.
# NOTE: if your served model is actually "gemma-3n-E4B-it", change HRF_LLM_MODEL only.
HRF_LLM_BASE_URL=http://localhost:50033/v1
HRF_LLM_MODEL=google/gemma-4-E4B-it
HRF_LLM_API_KEY=dummy-key
HRF_LLM_TEMPERATURE=0.1
HRF_LLM_MAX_TOKENS=1024
HRF_LLM_TIMEOUT=60
# Inside Docker the host's vLLM is not "localhost". Use host.docker.internal:
# HRF_LLM_BASE_URL=http://host.docker.internal:50033/v1

# ---- ChromaDB ----
# mode: ephemeral (in-memory, tests) | persistent (local file) | http (server)
HRF_CHROMA_MODE=persistent
HRF_CHROMA_HOST=chromadb
HRF_CHROMA_PORT=8000
HRF_CHROMA_PATH=data/chroma
HRF_CHROMA_COLLECTION=health_chunks

# ---- Embeddings ----
HRF_EMBED_MODEL=all-MiniLM-L6-v2

# ---- Storage ----
HRF_SQLITE_PATH=data/herefanmi.sqlite

# ---- Retrieval ----
HRF_DEFAULT_TOP_N=5
HRF_RRF_K=60
HRF_DENSE_CANDIDATES=20

# ---- Auth (backend) ----
HRF_JWT_SECRET=change-me-in-production
HRF_JWT_ALGORITHM=HS256
HRF_JWT_EXPIRE_MINUTES=1440
HRF_ADMIN_UID=admin
HRF_SIGNUP_POINTS=14

# ---- Inter-service URLs (backend → rag/llm) ----
HRF_RAG_URL=http://localhost:5000
HRF_LLM_URL=http://localhost:5002
